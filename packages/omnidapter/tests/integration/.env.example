OMNIDAPTER_INTEGRATION=1

OMNIDAPTER_TEST_GOOGLE_CLIENT_ID=your-google-client-id
OMNIDAPTER_TEST_GOOGLE_CLIENT_SECRET=your-google-client-secret
OMNIDAPTER_TEST_GOOGLE_REFRESH_TOKEN=your-google-refresh-token
# Optional: pin a specific calendar
# OMNIDAPTER_TEST_GOOGLE_CALENDAR_ID=primary

OMNIDAPTER_TEST_MICROSOFT_CLIENT_ID=your-microsoft-client-id
OMNIDAPTER_TEST_MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
OMNIDAPTER_TEST_MICROSOFT_REFRESH_TOKEN=your-microsoft-refresh-token
# OMNIDAPTER_TEST_MICROSOFT_CALENDAR_ID=

OMNIDAPTER_TEST_ZOHO_CLIENT_ID=your-zoho-client-id
OMNIDAPTER_TEST_ZOHO_CLIENT_SECRET=your-zoho-client-secret
OMNIDAPTER_TEST_ZOHO_REFRESH_TOKEN=your-zoho-refresh-token
# OMNIDAPTER_TEST_ZOHO_CALENDAR_ID=

# CalDAV
# OMNIDAPTER_TEST_CALDAV_URL=https://calendar.example.com/caldav/
# OMNIDAPTER_TEST_CALDAV_USERNAME=your-username
# OMNIDAPTER_TEST_CALDAV_PASSWORD=your-password
# OMNIDAPTER_TEST_CALDAV_CALENDAR_ID=

# Apple
# OMNIDAPTER_TEST_APPLE_USERNAME=your-apple-id@example.com
# OMNIDAPTER_TEST_APPLE_PASSWORD=your-app-specific-password
# OMNIDAPTER_TEST_APPLE_CALENDAR_ID=
