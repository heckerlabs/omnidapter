{
  "name": "@omnidapter/sdk",
  "version": "0.0.0",
  "type": "module",
  "description": "Omnidapter API client SDK",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"const f=require('fs');if(f.existsSync('src/apis/index.ts')){require('child_process').execSync('tsc',{stdio:'inherit'})}else{console.log('Skipping @omnidapter/sdk build: run scripts/generate_sdks.sh first')}\""
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": [
    "omnidapter",
    "calendar",
    "sdk",
    "api"
  ],
  "license": "MIT"
}
