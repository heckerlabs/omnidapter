{
  "name": "@heckerlabs/omnidapter-connect",
  "version": "1.0.0",
  "type": "module",
  "description": "Omnidapter Connect — embed a calendar authorization flow in your app",
  "main": "./dist/omnidapter-connect.umd.js",
  "module": "./dist/omnidapter-connect.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/omnidapter-connect.es.js",
      "require": "./dist/omnidapter-connect.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --emitDeclarationOnly --outDir dist && vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "omnidapter",
    "connect",
    "calendar",
    "oauth"
  ],
  "license": "MIT"
}
