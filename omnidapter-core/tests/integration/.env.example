# Optional: one or more attendee emails for invitee tests (comma-separated)
# OMNIDAPTER_TEST_ATTENDEE_EMAIL=you@example.com, teammate@example.com

OMNIDAPTER_TEST_GOOGLE_CLIENT_ID=your-google-client-id
OMNIDAPTER_TEST_GOOGLE_CLIENT_SECRET=your-google-client-secret
OMNIDAPTER_TEST_GOOGLE_REFRESH_TOKEN=your-google-refresh-token
# Optional: pin a specific calendar
# OMNIDAPTER_TEST_GOOGLE_CALENDAR_ID=primary

OMNIDAPTER_TEST_MICROSOFT_CLIENT_ID=your-microsoft-client-id
OMNIDAPTER_TEST_MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
OMNIDAPTER_TEST_MICROSOFT_REFRESH_TOKEN=your-microsoft-refresh-token
# OMNIDAPTER_TEST_MICROSOFT_CALENDAR_ID=

OMNIDAPTER_TEST_ZOHO_CLIENT_ID=your-zoho-client-id
OMNIDAPTER_TEST_ZOHO_CLIENT_SECRET=your-zoho-client-secret
OMNIDAPTER_TEST_ZOHO_REFRESH_TOKEN=your-zoho-refresh-token
# OMNIDAPTER_TEST_ZOHO_CALENDAR_ID=
# OMNIDAPTER_TEST_ZOHO_BOOKING_WORKSPACE_ID=   # optional; defaults to first workspace
# OMNIDAPTER_TEST_ZOHO_BOOKING_SERVICE_ID=      # optional; defaults to first service

OMNIDAPTER_TEST_ACUITY_CLIENT_ID=your-acuity-client-id
OMNIDAPTER_TEST_ACUITY_CLIENT_SECRET=your-acuity-client-secret
OMNIDAPTER_TEST_ACUITY_REFRESH_TOKEN=your-acuity-refresh-token

OMNIDAPTER_TEST_CALCOM_CLIENT_ID=your-calcom-client-id
OMNIDAPTER_TEST_CALCOM_CLIENT_SECRET=your-calcom-client-secret
OMNIDAPTER_TEST_CALCOM_REFRESH_TOKEN=your-calcom-refresh-token

OMNIDAPTER_TEST_SQUARE_CLIENT_ID=your-square-client-id
OMNIDAPTER_TEST_SQUARE_CLIENT_SECRET=your-square-client-secret
OMNIDAPTER_TEST_SQUARE_REFRESH_TOKEN=your-square-refresh-token

OMNIDAPTER_TEST_CALENDLY_CLIENT_ID=your-calendly-client-id
OMNIDAPTER_TEST_CALENDLY_CLIENT_SECRET=your-calendly-client-secret
OMNIDAPTER_TEST_CALENDLY_REFRESH_TOKEN=your-calendly-refresh-token

# Microsoft Bookings (separate from Microsoft Calendar — different client app)
OMNIDAPTER_TEST_MSBOOKINGS_CLIENT_ID=your-ms-bookings-client-id
OMNIDAPTER_TEST_MSBOOKINGS_CLIENT_SECRET=your-ms-bookings-client-secret
OMNIDAPTER_TEST_MSBOOKINGS_REFRESH_TOKEN=your-ms-bookings-refresh-token
OMNIDAPTER_TEST_MSBOOKINGS_BUSINESS_ID=yourbusiness@example.com

# CalDAV
# OMNIDAPTER_TEST_CALDAV_URL=https://calendar.example.com/caldav/
# OMNIDAPTER_TEST_CALDAV_USERNAME=your-username
# OMNIDAPTER_TEST_CALDAV_PASSWORD=your-password
# OMNIDAPTER_TEST_CALDAV_CALENDAR_ID=

# Apple
# OMNIDAPTER_TEST_APPLE_USERNAME=your-apple-id@example.com
# OMNIDAPTER_TEST_APPLE_PASSWORD=your-app-specific-password
# OMNIDAPTER_TEST_APPLE_CALENDAR_ID=
