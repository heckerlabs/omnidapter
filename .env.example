# ============================================================
# Omnidapter Self-Hosted Configuration
# ============================================================
# Copy to .env and fill in the values before running:
#   cp .env.example .env
#   docker compose up -d

# ----- Required -----------------------------------------------

# PostgreSQL password (shared by db and api services)
DB_PASSWORD=change_me

# 32-byte AES-256-GCM encryption key (base64-encoded)
# Generate with: openssl rand -base64 32
OMNIDAPTER_ENCRYPTION_KEY=

# Public URL of your API (used to build OAuth callback URLs)
OMNIDAPTER_BASE_URL=http://localhost:8000

# ----- OAuth Provider Credentials (at least one) --------------

OMNIDAPTER_GOOGLE_CLIENT_ID=
OMNIDAPTER_GOOGLE_CLIENT_SECRET=

OMNIDAPTER_MICROSOFT_CLIENT_ID=
OMNIDAPTER_MICROSOFT_CLIENT_SECRET=

OMNIDAPTER_ZOHO_CLIENT_ID=
OMNIDAPTER_ZOHO_CLIENT_SECRET=

# ----- Initial API Key (server only) -------------------------
# Set to seed an API key on server startup (no bootstrap script needed).
# Format: omni_live_<32 random chars>  or  omni_test_<32 random chars>
# Generate with: python -c "import secrets,string; print('omni_live_'+''.join(secrets.choice(string.ascii_letters+string.digits) for _ in range(32)))"
# Leave blank if you use the bootstrap script instead.
OMNIDAPTER_INITIAL_API_KEY=

# ----- WorkOS (hosted only) -----------------------------------
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# Must be exactly 32+ characters — used to encrypt the session cookie
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
WORKOS_COOKIE_PASSWORD=

# ----- Optional (defaults shown) ------------------------------

OMNIDAPTER_ENV=production
API_PORT=8000

OMNIDAPTER_FREE_TIER_CALLS=1000
OMNIDAPTER_RATE_LIMIT_FREE=60
OMNIDAPTER_RATE_LIMIT_PAID=300

# ----- Billing (optional) -------------------------------------

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
