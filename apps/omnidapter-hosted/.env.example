# Quick start (from apps/omnidapter-hosted):
#   cp .env.example .env && docker-compose up -d --build

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose overrides
# Server bind host/port (compose + local run)
HOST=0.0.0.0
PORT=8000

# Compose always runs migrations and uses local Postgres (`db`) credentials.
# For non-compose runs, uncomment and set OMNIDAPTER_DATABASE_URL explicitly.
# OMNIDAPTER_DATABASE_URL=postgresql+asyncpg://localhost/omnidapter

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Required for DEV/PROD. Optional in LOCAL (credentials stored in plaintext with warning).
OMNIDAPTER_ENCRYPTION_KEY=
# Used during key rotation
OMNIDAPTER_ENCRYPTION_KEY_PREVIOUS=

# ── OAuth state store ─────────────────────────────────────────────────────────
# Compose hosted ignores these and always uses local redis service URLs.
# For non-compose runs, uncomment and set explicitly.
# OMNIDAPTER_OAUTH_STATE_REDIS_URL=redis://localhost:6379/0
# HOSTED_RATE_LIMIT_REDIS_URL=redis://localhost:6379/1

# ── Apple (CalDAV — no OAuth required) ───────────────────────────────────────
# Set to 1/true/yes/on to enable
OMNIDAPTER_APPLE_ENABLED=

# ── App ───────────────────────────────────────────────────────────────────────
OMNIDAPTER_BASE_URL=http://localhost:8000
# DEV (default), LOCAL (plaintext fallback if no key), PROD
OMNIDAPTER_ENV=DEV
# e.g. app.example.com,*.preview.example.com
OMNIDAPTER_ALLOWED_ORIGIN_DOMAINS=*

# ── Stripe (billing) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── WorkOS (user auth) ────────────────────────────────────────────────────────
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# ── Rate limits (requests per 60 s window) ────────────────────────────────────
HOSTED_RATE_LIMIT_FREE=60
HOSTED_RATE_LIMIT_PAID=600

# ── Free tier ─────────────────────────────────────────────────────────────────
# Calendar API calls per tenant per month
HOSTED_FREE_TIER_CALLS=1000
