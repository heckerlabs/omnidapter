# Quick start (from apps/omnidapter-server):
#   cp .env.example .env && docker-compose --env-file .env up -d --build

# Docker Compose overrides
# Server bind host/port
HOST=0.0.0.0
PORT=8000

# App Settings
OMNIDAPTER_BASE_URL=http://localhost:8000
# DEV (default), LOCAL (plaintext fallback if no key), PROD
OMNIDAPTER_ENV=DEV
# e.g. dashboard.example.com,*.preview.example.com
OMNIDAPTER_ALLOWED_ORIGIN_DOMAINS=*

# Compose always runs migrations and uses local Postgres (`db`) credentials.
# For non-compose runs, uncomment and set OMNIDAPTER_DATABASE_URL explicitly.
# OMNIDAPTER_DATABASE_URL=postgresql+asyncpg://localhost/omnidapter

# Encryption
# Generate with: `openssl rand -base64 32`. Required outside LOCAL env.
OMNIDAPTER_ENCRYPTION_KEY=
# Used during key rotation
OMNIDAPTER_ENCRYPTION_KEY_PREVIOUS=

# OAuth state store
# Priority: Redis > DB > in-memory
# Compose server ignores these and uses local DB-backed state store.
# e.g. redis://localhost:6379/0
OMNIDAPTER_OAUTH_STATE_REDIS_URL=
# Defaults to OMNIDAPTER_DATABASE_URL if empty
OMNIDAPTER_OAUTH_STATE_DB_URL=

# Providers - configure at least one
OMNIDAPTER_GOOGLE_CLIENT_ID=
OMNIDAPTER_GOOGLE_CLIENT_SECRET=
OMNIDAPTER_MICROSOFT_CLIENT_ID=
OMNIDAPTER_MICROSOFT_CLIENT_SECRET=
OMNIDAPTER_ZOHO_CLIENT_ID=
OMNIDAPTER_ZOHO_CLIENT_SECRET=
# Set to 1/true/yes/on to enable Apple provider
OMNIDAPTER_APPLE_ENABLED=

OMNIDAPTER_FALLBACK_CONNECTION_LIMIT=5
OMNIDAPTER_REAUTH_THRESHOLD=3
