# ── Database ──────────────────────────────────────────────────────────────────
OMNIDAPTER_DATABASE_URL=postgresql+asyncpg://omnidapter:password@localhost:5432/omnidapter

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OMNIDAPTER_ENCRYPTION_KEY=
OMNIDAPTER_ENCRYPTION_KEY_PREVIOUS=   # used during key rotation

# ── OAuth state store ─────────────────────────────────────────────────────────
# Priority: Redis > DB > in-memory (in-memory warns on startup)
OMNIDAPTER_OAUTH_STATE_REDIS_URL=      # e.g. redis://localhost:6379/0
OMNIDAPTER_OAUTH_STATE_DB_URL=         # defaults to OMNIDAPTER_DATABASE_URL if empty

# ── OAuth provider credentials ────────────────────────────────────────────────
# At least one provider must be configured (or enable Apple below).
OMNIDAPTER_GOOGLE_CLIENT_ID=
OMNIDAPTER_GOOGLE_CLIENT_SECRET=
OMNIDAPTER_MICROSOFT_CLIENT_ID=
OMNIDAPTER_MICROSOFT_CLIENT_SECRET=
OMNIDAPTER_ZOHO_CLIENT_ID=
OMNIDAPTER_ZOHO_CLIENT_SECRET=

# ── Apple (CalDAV — no OAuth required) ───────────────────────────────────────
OMNIDAPTER_APPLE_ENABLED=              # set to 1/true/yes/on to enable

# ── Limits ────────────────────────────────────────────────────────────────────
OMNIDAPTER_FALLBACK_CONNECTION_LIMIT=5
OMNIDAPTER_REAUTH_THRESHOLD=3

# ── App ───────────────────────────────────────────────────────────────────────
OMNIDAPTER_BASE_URL=http://localhost:8000
OMNIDAPTER_ENV=development
