# === App Settings ===

HOST=0.0.0.0
PORT=8000

# === Base Omnidapter Settings ===

OMNIDAPTER_BASE_URL=http://localhost:8000
# Environment: PROD | DEV | LOCAL
OMNIDAPTER_ENV=PROD
# Auth Mode: required | disabled (can only disable in LOCAL)
OMNIDAPTER_AUTH_MODE=required
# API Key: required when OMNIDAPTER_AUTH_MODE=required.
OMNIDAPTER_API_KEY=
# Allowed Origins: dashboard.example.com,*.preview.example.com
OMNIDAPTER_ALLOWED_ORIGIN_DOMAINS=*
# Postgres Database URL. Defaults to docker-compose instance.
OMNIDAPTER_DATABASE_URL=

# Encryption
# Generate with: `openssl rand -base64 32`. Required outside LOCAL env.
OMNIDAPTER_ENCRYPTION_KEY=
# Used during key rotation
OMNIDAPTER_ENCRYPTION_KEY_PREVIOUS=

# OAuth state store. Redis is preferred for multi-worker deployments. Falls back to local in-memory if not set.
OMNIDAPTER_OAUTH_STATE_REDIS_URL=

# Redis key prefix. Allows multiple environments (dev, qa, prod) to share a single Redis instance.
OMNIDAPTER_REDIS_PREFIX=omnidapter

# Link token TTL in seconds
OMNIDAPTER_LINK_TOKEN_TTL_SECONDS=60

# Providers - configure at least one
OMNIDAPTER_GOOGLE_CLIENT_ID=
OMNIDAPTER_GOOGLE_CLIENT_SECRET=
OMNIDAPTER_MICROSOFT_CLIENT_ID=
OMNIDAPTER_MICROSOFT_CLIENT_SECRET=
OMNIDAPTER_ZOHO_CLIENT_ID=
OMNIDAPTER_ZOHO_CLIENT_SECRET=
# Set to 1/true/yes/on to enable Apple provider
OMNIDAPTER_APPLE_ENABLED=0
# Set to 1/true/yes/on to enable CalDAV provider
OMNIDAPTER_CALDAV_ENABLED=0
